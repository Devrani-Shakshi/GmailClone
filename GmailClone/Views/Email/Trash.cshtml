@model IEnumerable<GmailClone.Models.EmailMessage>
@{
    ViewData["Title"] = "Trash";
}

<div class="p-3 border-bottom bg-white sticky-top" style="top: 56px;">
    <h5 class="m-0 text-muted"><i class="bi bi-trash me-2"></i> Trash</h5>
</div>

<div class="table-responsive">
    <table class="table table-hover text-muted">
        <tbody>
            @foreach (var email in Model)
            {
                <tr class="border-bottom" onclick="location.href='/Email/Details/@email.Id'" style="cursor:pointer;">
                    <td style="width: 50px;" class="ps-3"><i class="bi bi-trash"></i></td>
                    <td style="width: 200px;">@email.From</td>
                    <td><del>@email.Subject</del></td>
                    <td class="text-end pe-3">@email.DateSent.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
</div>
