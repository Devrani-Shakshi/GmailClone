
@model IEnumerable<GmailClone.Models.EmailMessage>
@{
    ViewData["Title"] = "Sent Mail";
}

<style>
    /* Sent folder specific animations */
    .sent-row {
        transition: all 0.25s ease;
        border-left: 4px solid transparent;
        background: white;
    }

        .sent-row:hover {
            background-color: #f8f9ff !important;
            border-left: 4px solid #0d6efd; /* Blue for Sent */
            transform: translateX(5px);
        }

    .plane-icon {
        color: #0d6efd;
        opacity: 0.6;
        transition: transform 0.3s;
    }

    .sent-row:hover .plane-icon {
        transform: translate(5px, -5px);
        opacity: 1;
    }

    .recipient-tag {
        background: #e7f0ff;
        color: #0d6efd;
        font-weight: 500;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
    }
</style>

<!-- Header Area -->
<div class="d-flex justify-content-between align-items-center p-4 border-bottom bg-white sticky-top" style="top: 0; z-index: 10;">
    <div class="d-flex align-items-center">
        <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
            <i class="bi bi-send-fill text-primary fs-5"></i>
        </div>
        <h5 class="m-0 fw-bold text-dark">Sent Messages</h5>
    </div>
    <div class="text-muted small">
        Total: @Model.Count() outbox items
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center py-5">
                        <i class="bi bi-send-exclamation display-4 text-light"></i>
                        <p class="text-muted mt-3">You haven't sent any emails yet.</p>
                        <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#composeModal">Send your first mail</button>
                    </td>
                </tr>
            }

            @foreach (var email in Model)
            {
                <tr class="sent-row border-bottom" onclick="location.href='/Email/Details/@email.Id'" style="cursor:pointer;">

                    <!-- Icon Column -->
                    <td style="width: 60px;" class="ps-4">
                        <i class="bi bi-send-fill plane-icon fs-5"></i>
                    </td>

                    <!-- Recipient Column -->
                    <td style="width: 250px;">
                        <span class="recipient-tag">To: @email.To.Split('@')[0]</span>
                        <div class="text-muted x-small mt-1" style="font-size: 0.75rem;">@email.To</div>
                    </td>

                    <!-- Subject and Preview -->
                    <td>
                        <div class="text-truncate" style="max-width: 550px;">
                            <span class="fw-bold text-dark">@email.Subject</span>
                            <span class="text-muted fw-normal ms-2"> — @(email.Body.Length > 70 ? email.Body.Substring(0, 70) + "..." : email.Body)</span>
                        </div>
                    </td>

                    <!-- Date & Attachment -->
                    <td class="text-end pe-4 text-muted small" style="width: 150px;">
                        @if (!string.IsNullOrEmpty(email.AttachmentPath))
                        {
                            <i class="bi bi-paperclip me-2" title="Has Attachment"></i>
                        }
                        @email.DateSent.ToString("MMM dd")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
