@model IEnumerable<GmailClone.Models.EmailMessage>
@{
    ViewData["Title"] = "Starred";
}

<div class="p-3 border-bottom bg-white sticky-top" style="top: 56px;">
    <h5 class="m-0"><i class="bi bi-star-fill text-warning me-2"></i> Starred</h5>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <tbody>
            @foreach (var email in Model)
            {
                <tr class="border-bottom" onclick="location.href='/Email/Details/@email.Id'" style="cursor:pointer;">
                    <td style="width: 50px;" class="ps-3"><i class="bi bi-star-fill text-warning"></i></td>
                    <td style="width: 200px;">@email.From</td>
                    <td>@email.Subject</td>
                    <td class="text-end pe-3">@email.DateSent.ToString("MMM dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
