@model IEnumerable<GmailClone.Models.EmailMessage>
@{
    ViewData["Title"] = "Inbox";
}

<div class="p-3 border-bottom bg-white sticky-top" style="top: 56px;">
    <h5 class="m-0"><i class="bi bi-inbox me-2"></i> Inbox</h5>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <tbody>
            @foreach (var email in Model)
            {
                <tr class="@(email.IsRead ? "text-muted" : "fw-bold bg-light") border-bottom" onclick="location.href='/Email/Details/@email.Id'" style="cursor:pointer;">
                    <td style="width: 50px;" class="ps-3"><input type="checkbox" class="form-check-input"></td>
                    <td style="width: 200px;">@email.From</td>
                    <td>@email.Subject - <span class="fw-normal text-muted">@email.Body.Substring(0, Math.Min(20, email.Body.Length))...</span></td>
                    <td class="text-end pe-3">@email.DateSent.ToString("MMM dd")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
